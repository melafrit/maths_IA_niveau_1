# ═══════════════════════════════════════════════════════════════════════════
# Laravel (dans src/ après Phase P0)
# ═══════════════════════════════════════════════════════════════════════════

src/vendor/
src/node_modules/
src/public/build/
src/public/hot
src/public/storage
src/storage/*.key
src/storage/pail/
src/storage/app/backups/
src/storage/app/exports/
src/storage/app/public/
src/storage/framework/cache/
src/storage/framework/sessions/
src/storage/framework/testing/
src/storage/framework/views/
src/storage/logs/
src/bootstrap/cache/

# ═══════════════════════════════════════════════════════════════════════════
# Environnement (ne JAMAIS commit)
# ═══════════════════════════════════════════════════════════════════════════

src/.env
src/.env.backup
src/.env.production
src/.env.local
src/.env.*.local
.env
.env.backup

